// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User-private docs
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Example collection created by the sample API
    match /items/{id} {
      allow read: if true;
      allow write, update, delete: if request.auth != null && request.auth.uid == resource.data.owner;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner;
    }

    // TEMP - Allow everything else by default
    match /{document=**} { allow read, write: if true; }
  }
  
}
